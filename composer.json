{
    "name": "gemorroj/whordap",
    "description": "WHOIS/RDAP client",
    "keywords": ["whois","phpwhois", "rdap", "phprdap", "lookup"],
    "type": "library",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Gemorroj"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-curl": "*",
        "ext-pcre": "*",
        "algo26-matthias/idna-convert": "^4.2.1",
        "psr/log": "^3.0.2",
        "psr/cache": "^3.0.0",
        "symfony/polyfill-mbstring": "^1.36"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1.5",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1.48",
        "symfony/console": "^7.4.8 || ^8.0.8",
        "symfony/cache": "^7.4.8 || ^8.0.8"
    },
    "autoload": {
        "psr-4": {
            "WhoRdap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WhoRdap\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "ext-mbstring": "*"
    }
}
